# ──────────────────────────────────────────────
# AWAAZ360 Render Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────

# Server Port (Render sets this via the PORT env var in render.yaml)
PORT=3001

# City & Location (for weather & prayer times)
CITY=Rawalpindi
COUNTRY=Pakistan
LATITUDE=33.6007
LONGITUDE=73.0679
TIMEZONE=Asia/Karachi

# WeatherAPI.com Key (for live weather data)
# Get from: https://www.weatherapi.com/my/
WEATHER_API_KEY=your_weather_api_key_here

# OpenAI API Key (for chatbot feature)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Tavily API Key (for news & fuel price search)
# Get from: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Fuel Webhook Token (optional, for auto-refreshing fuel prices)
FUEL_WEBHOOK_TOKEN=
